# Copy to e2e/.env and adjust. Consumed by the runner / provisioning scripts.
# All values below are the compose defaults; override only if you remap ports.

KONTABLO_URL=http://localhost:8000

# ERPNext (parent, Spain/PGC/EUR)
ERPNEXT_URL=http://localhost:8081
ERPNEXT_COMPANY=Iberia Holding
ERPNEXT_USER=Administrator
ERPNEXT_PASSWORD=admin
# Leave key/secret empty to auto-mint one from USER/PASSWORD on first provision.
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=

# Odoo (subsidiary, Mexico/SAT/MXN)
ODOO_URL=http://localhost:8069
ODOO_DB=kontablo
ODOO_USER=admin
ODOO_PASSWORD=admin
ODOO_MASTER_PASSWORD=admin
ODOO_COMPANY=Azteca Servicios
