\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces The Three-Tier Resolution Pipeline. Local ERP accounts pass through exact code checks (Tier 1) and rule-based regex parsing (Tier 2) before falling back to Semantic AI (Tier 3). If the AI mapping returns a confidence score below 0.80, or if it violates deterministic boundaries, it is flagged for manual review.}}{18}{figure.4}\protected@file@percent }
\newlabel{fig:three_tier_pipeline}{{4}{18}{The Three-Tier Resolution Pipeline. Local ERP accounts pass through exact code checks (Tier 1) and rule-based regex parsing (Tier 2) before falling back to Semantic AI (Tier 3). If the AI mapping returns a confidence score below 0.80, or if it violates deterministic boundaries, it is flagged for manual review}{figure.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces The deterministic boundary checklist verifies AI-proposed mappings prior to ledger write-in.}}{19}{figure.5}\protected@file@percent }
